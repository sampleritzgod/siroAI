# Copy to .env.local for development.
# Do NOT wrap values in quotes in the Vercel UI.

# Postgres (required)
# Example: postgresql://USER:PASSWORD@host/db?sslmode=require
DATABASE_URL=

# Clerk (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Model providers
# OPENAI_API_KEY is enough for everything (chat + Consensus + RAG embeddings).
# Consensus panel: gpt-4o-mini, gpt-4o, gpt-4.1-mini → evaluator: gpt-4o
# RAG uses OpenAI text-embedding-3-small + pgvector on Postgres.
OPENAI_API_KEY=

# Optional — not required
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Tavily (optional — live web search in chat)
TAVILY_API_KEY=

# Upstash Redis (optional — conversation/timeline cache + rate limits)
# Without these, the app uses an in-process memory fallback (fine for local).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (required on Vercel for uploads; optional locally)
# Locally without this, files go under .data/uploads and /api/files/[id].
# On Vercel, missing this token causes uploads to fail (ephemeral disk).
BLOB_READ_WRITE_TOKEN=

# Sentry (optional — exception capture on API routes)
SENTRY_DSN=

# Set to true in CI when secrets are not available (lint/typecheck only).
SKIP_ENV_VALIDATION=
