    "@clerk/nextjs": "^7.5.20",
    "@napi-rs/canvas": "^1.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.66.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.6.1",
    "ai": "^7.0.31",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "next": "16.2.10",
